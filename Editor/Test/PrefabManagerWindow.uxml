<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" editor-extension-mode="True">
    <Style src="project://database/Assets/Test/PrefabManagerWindow.uss?fileID=7433441132597879392&amp;guid=de92207f79204e898967bd8cfa394f85&amp;type=3#PrefabManagerWindow" />
    <Style src="project://database/Assets/Test/PrefabItem.uss?fileID=7433441132597879392&amp;guid=17db160ccbea4f6fbf366f0a728179a5&amp;type=3#PrefabItem" />
    <ui:VisualElement name="root-container" style="flex-grow: 1; flex-direction: column; background-color: rgb(30, 30, 30);">
        <ui:VisualElement name="global-toolbar" style="padding: 10px 20px; border-bottom-width: 1px; border-bottom-color: rgb(58, 58, 58); border-bottom-style: solid; flex-shrink: 0; background-color: rgb(42, 42, 42); flex-direction: row; justify-content: space-between; align-items: center;">
            <ui:Label name="folderInfo" text="根目录 · 0 项" style="font-size: 13px; color: rgb(176, 184, 197);" />
            <ui:Button name="newFolderButton" text="+ 新建文件夹" style="background-color: rgb(43, 106, 158); color: white; border-width: 0; border-radius: 8px; padding: 8px 16px;" />
        </ui:VisualElement>
        <ui:TwoPaneSplitView name="splitView" orientation="Horizontal" fixedPaneIndex="0" fixedPaneWidth="260" style="flex-grow: 1;">
            <ui:VisualElement name="sidebar" style="background-color: rgb(42, 42, 42); border-right-width: 1px; border-right-color: rgb(58, 58, 58); border-right-style: solid; overflow: hidden;">
                <ui:VisualElement name="sidebar-header" style="padding: 14px 20px 10px 20px; border-bottom-width: 1px; border-bottom-color: rgb(58, 58, 58); border-bottom-style: solid; flex-shrink: 0; flex-direction: row; justify-content: space-between;">
                    <ui:Label text="[F] 目录" style="font-size: 13px; font-weight: 600; color: rgb(176, 184, 197); -unity-font-style: bold;" />
                    <ui:Label name="folderCount" text="0" style="background-color: rgb(51, 51, 51); padding-left: 10px; padding-right: 10px; border-radius: 12px; font-size: 12px; color: rgb(176, 184, 197); border-width: 1px; border-color: rgb(74, 74, 74);" />
                </ui:VisualElement>
                <ui:TreeView name="folderTreeView" style="flex-grow: 1; padding: 8px 12px 16px 12px;" />
            </ui:VisualElement>
            <ui:VisualElement name="file-area" style="background-color: rgb(30, 30, 30); flex-direction: column;">
                <ui:VisualElement name="listContainer" style="flex-grow: 1; padding: 8px 16px 16px 16px; overflow: hidden; position: relative;">
                    <ui:Label name="dragOverlay" text="释放预制体以上传" style="position: absolute; inset: 16px; border-width: 3px; border-color: rgb(109, 171, 240); border-style: dashed; border-radius: 16px; font-size: 20px; font-weight: 500; color: rgb(109, 171, 240); background-color: rgba(43, 106, 158, 0.15); align-items: center; justify-content: center; display: none;" />
                </ui:VisualElement>
            </ui:VisualElement>
        </ui:TwoPaneSplitView>
    </ui:VisualElement>
</ui:UXML>
