/* ============================================================
   列表项样式（应用于 .prefab-item）
   ============================================================ */
.prefab-item {
    flex-direction: row;
    align-items: center;
    height: 44px;
    margin-bottom: 4px;          /* 行间距 */
    padding-left: 8px;
    padding-right: 8px;
    border-radius: 4px;          /* 简写，兼容 Unity */
    border-width: 0;             /* 移除默认边框 */
}
.prefab-item .item-icon {
    width: 32px;
    height: 32px;
    margin-right: 10px;
}
.prefab-item .item-name {
    flex-grow: 1;
    font-size: 14px;
    -unity-text-align: middle-left;
}